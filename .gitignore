# ---- Large binary assets (kept locally, NOT pushed to GitHub) ----
# Keep folder structure on GitHub via .gitkeep placeholders.
dataset/*
!dataset/.gitkeep

checkpoints/*
!checkpoints/.gitkeep

model/weights/*
!model/weights/.gitkeep

output/videos/*
!output/videos/.gitkeep

output/json/*
!output/json/.gitkeep

output/calibration/*
!output/calibration/.gitkeep

# Per-video generated outputs (annotated videos and radar timelines)
output/*/
!output/calibration/
!output/json/
!output/videos/

# Scratch outputs and local analysis artifacts
temp/

# Vendored third-party source (re-clone separately if needed)
third_party/

# ---- Model / notebook artifacts ----
*.pt
*.pth
*.ipynb
.ipynb_checkpoints/

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Backups ----
*.backup
collision_avoidance/monitorVehicle.py.backup

# ---- Local-only docs / tests ----
CLAUDE.md
tests/

# ---- Logs ----
*.log
